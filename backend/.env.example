# Port chạy API Server (Mặc định: 5000)
PORT=5000

# Google Gemini API Key (Bắt buộc để sử dụng AI chấm điểm)
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase Credentials (Nếu bỏ trống, hệ thống tự kích hoạt Mock Local DB để chạy thử nghiệm)
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_key
